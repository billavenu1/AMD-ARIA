# ARIA Environment Configuration Example
# Copy this file to .env and customize as needed

# =============================================================================
# REQUIRED
# =============================================================================

# Encryption key for storing API credentials securely in the database
OPEN_NOTEBOOK_ENCRYPTION_KEY=your-secret-key-here

# =============================================================================
# DATABASE
# =============================================================================
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# =============================================================================
# AI Provider API Keys
# =============================================================================
# Google AI
GOOGLE_API_KEY=your-api-key-here

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Default Models
DEFAULT_CHAT_MODEL=gemini-3.1-flash-lite-preview
DEFAULT_EMBEDDING_MODEL=gemini-embedding-2
EXTRA_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-3.1-pro-preview

# =============================================================================
# Advanced Configuration
# =============================================================================
# API_URL=http://localhost:5055
# OLLAMA_BASE_URL=http://localhost:11434
